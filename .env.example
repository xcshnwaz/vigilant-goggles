# -------------------------------------------------------
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# Your Telegram bot token from @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Display name shown as MP3 performer tag
BOT_NAME=AudioBot

# Render settings (set automatically on Render.com)
# RENDER_EXTERNAL_HOSTNAME is injected by Render - leave blank locally
RENDER_EXTERNAL_HOSTNAME=your-service.onrender.com
PORT=10000

# MongoDB (MongoDB Atlas recommended for Render deploys)
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=audiobot

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Audio settings
MAX_FILE_BYTES=52428800   # 50 MB
FFMPEG_TIMEOUT=180
AUDIO_BITRATE=192k
AUDIO_SAMPLERATE=44100
